# Environment Variables
#
# Copy this file to .env and fill in the values.
# See DESIGN_DOCUMENT.md §15.7 for descriptions.

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=laserledger
DB_USER=laserledger
DB_PASSWORD=

# Auth
JWT_SECRET=
GOOGLE_CLIENT_ID=

# Email (leave SMTP_HOST empty for console-only mode in dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=LaserLedger <noreply@lasertools.org>

# Application
APP_BASE_URL=http://localhost:3000
NODE_ENV=development

# Admin bootstrap (creates admin user on first startup)
ADMIN_EMAIL=
ADMIN_INITIAL_PASSWORD=

# Uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=5242880
