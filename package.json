{
  "name": "laserledger",
  "version": "0.1.0",
  "private": true,
  "description": "Community-driven database of laser engraving and cutting settings",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server/src/index.ts",
    "dev:client": "npm --prefix client run dev",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc -p server/tsconfig.json && tsc-alias -p server/tsconfig.json",
    "build:client": "npm --prefix client run build",
    "start": "node server/dist/server/src/index.js",
    "migrate": "knex --knexfile server/src/db/knexfile.ts migrate:latest",
    "migrate:rollback": "knex --knexfile server/src/db/knexfile.ts migrate:rollback",
    "seed": "knex --knexfile server/src/db/knexfile.ts seed:run",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:mysql": "cross-env NODE_ENV=test_mysql vitest run",
    "test:client": "npm --prefix client run test",
    "test:e2e": "playwright test",
    "lint": "eslint \"server/**/*.ts\" \"shared/**/*.ts\"",
    "typecheck": "tsc -p server/tsconfig.json --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "mime-types": "^3.0.2",
    "multer": "^2.1.1",
    "mysql2": "^3.11.5",
    "nanoid": "^5.0.9",
    "nodemailer": "^8.0.5",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.53.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/mime-types": "^3.0.1",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^4.1.4",
    "better-sqlite3": "^12.9.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.1",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=22"
  }
}
