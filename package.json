{
  "name": "laserledger",
  "version": "0.1.0",
  "private": true,
  "description": "Community-driven database of laser engraving and cutting settings",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server/src/index.ts",
    "dev:client": "npm --prefix client run dev",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc -p server/tsconfig.json",
    "build:client": "npm --prefix client run build",
    "start": "node server/dist/server/src/index.js",
    "migrate": "knex --knexfile server/src/db/knexfile.ts migrate:latest",
    "migrate:rollback": "knex --knexfile server/src/db/knexfile.ts migrate:rollback",
    "seed": "knex --knexfile server/src/db/knexfile.ts seed:run",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:mysql": "cross-env NODE_ENV=test_mysql vitest run",
    "test:client": "npm --prefix client run test",
    "test:e2e": "playwright test",
    "lint": "eslint \"server/**/*.ts\" \"shared/**/*.ts\"",
    "typecheck": "tsc -p server/tsconfig.json --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "google-auth-library": "^9.15.0",
    "knex": "^3.1.0",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.5",
    "nanoid": "^5.0.9",
    "nodemailer": "^6.9.16",
    "sharp": "^0.33.5",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/mime-types": "^2.1.4",
    "@types/multer": "^1.4.12",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^6.4.17",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@axe-core/playwright": "^4.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "better-sqlite3": "^11.7.0",
    "eslint": "^9.17.0",
    "cross-env": "^7.0.3",
    "@playwright/test": "^1.53.2",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22"
  }
}
